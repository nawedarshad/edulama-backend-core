enum EducationalStage {
  KINDERGARTEN
  PRIMARY
  MIDDLE
  SECONDARY
  SENIOR_SECONDARY
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Todo {
  id       Int        @id @default(autoincrement())
  schoolId Int
  userId   Int
  text     String
  status   TodoStatus @default(TODO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, userId])
}

enum GradingSystem {
  PERCENTAGE
  LETTER
  GPA
}

enum PromotionPolicy {
  AUTO
  MANUAL
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceMode {
  DAILY
  PERIOD_WISE
}

enum AttendanceTrackingStrategy {
  ATTENDANCE_SIMPLE
  GATE_MARKING
  TAKER_MARKING
  ONLY_ATTENDANCE
  ATTENDANCE_AND_LATE_SEPARATE
  LATE_IN_ATTENDANCE
}

enum DailyAttendanceAccess {
  CLASS_TEACHER
  FIRST_PERIOD_TEACHER
}

enum LateMarkingResponsibility {
  GATEKEEPER
  TAKER
  CLASS_TEACHER
  FIRST_PERIOD_TEACHER
}

enum LateAttendanceStatus {
  PRESENT
  LATE
  HALFDAY
  ABSENT
}

model SchoolSettings {
  id       Int @id @default(autoincrement())
  schoolId Int @unique

  // Branding
  motto               String?
  backgroundImageUrl  String?
  logoUrl             String?
  faviconUrl          String?
  landingPageTemplate Int     @default(1)
  landingPageConfig   Json?

  // Address
  street  String?
  city    String?
  state   String?
  zipCode String?
  country String?

  // Contact
  phone   String?
  email   String?
  website String?

  // Academic
  attendanceMode        AttendanceMode             @default(DAILY)
  trackingStrategy      AttendanceTrackingStrategy @default(ATTENDANCE_SIMPLE)
  dailyAttendanceAccess DailyAttendanceAccess      @default(CLASS_TEACHER)
  gradingSystem         GradingSystem         @default(PERCENTAGE)
  promotionPolicy       PromotionPolicy       @default(MANUAL)

  // School Day Timings
  schoolStartTime DateTime
  schoolEndTime   DateTime

  // Timetable
  maxPeriodsPerDay       Int     @default(8)
  minGapBetweenPeriods   Int?
  flexiblePeriodDuration Boolean @default(false)
  defaultPeriodLength    Int     @default(45)

  // Attendance
  lateMarkThreshold         Int?
  lateMarkingResponsibility LateMarkingResponsibility @default(TAKER)
  lateCountingPolicy       LateAttendanceStatus       @default(LATE)
  isTrackingStrategyLocked  Boolean                    @default(false)
  absentAfter               Int?
  allowExcuseSubmission     Boolean                    @default(true)

  // Academic constraints
  maxSubjectsPerStudent     Int @default(8)
  maxRepeatPeriodsPerDay    Int @default(2)
  maxConsecutiveSameSubject Int @default(2)
  isWebsitePublic           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model TimeSlot {
  id             Int       @id @default(autoincrement())
  schoolId       Int
  academicYearId Int
  scheduleId     Int?
  day            DayOfWeek
  periodId       Int?

  startTime String // "09:00"
  endTime   String // "09:45"

  // description String? <- REMOVED
  isBreak Boolean @default(false)

  schedule           Schedule?           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  period             TimePeriod?         @relation(fields: [periodId], references: [id], onDelete: Cascade)
  timetableEntries   TimetableEntry[]
  attendanceSessions AttendanceSession[]
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  // In multi-institution, slots may not have formal schedules. We only enforce unique if schedule exists.
  // Actually, a slot is unique per school, day, start, and end time. Schedule is just an organizational folder.
  @@unique([schoolId, day, startTime, endTime])
  @@unique([id, schoolId])
  @@index([schoolId, day, scheduleId])
}

model WebPage {
  id             Int     @id @default(autoincrement())
  schoolId       Int
  slug           String
  title          String
  content        Json // List of blocks: [{ type: "hero", data: {...} }, ...]
  isPublished    Boolean @default(false)
  seoTitle       String?
  seoDescription String?
  isHomePage     Boolean @default(false) // To mark a page as the landing page

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, slug])
  @@index([schoolId])
}

model PlatformSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique // e.g., 'HELP_SUPPORT_EMAIL'
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebMenu {
  id        Int           @id @default(autoincrement())
  schoolId  Int
  name      String
  location  String        @default("HEADER")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  school    School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items     WebMenuItem[]

  @@index([schoolId])
}

model WebMenuItem {
  id        Int           @id @default(autoincrement())
  menuId    Int
  label     String
  type      String        @default("URL")
  value     String
  target    String        @default("_self")
  parentId  Int?
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  menu      WebMenu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent    WebMenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  WebMenuItem[] @relation("MenuHierarchy")

  @@index([menuId])
  @@index([parentId])
}
