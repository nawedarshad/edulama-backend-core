enum GrievanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum GrievancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum GrievanceCategory {
  ACADEMIC
  ADMISSION
  FEES
  INFRASTRUCTURE
  TRANSPORT
  CONDUCT
  STAFF_RELATED
  OTHER
}

model Grievance {
  id Int @id @default(autoincrement())

  // Tenant & academic isolation
  schoolId       Int
  academicYearId Int

  // Who raised the grievance
  raisedById Int
  raisedBy   User @relation(fields: [raisedById], references: [id], onDelete: Cascade)

  // Configuration
  category    GrievanceCategory @default(OTHER)
  priority    GrievancePriority @default(MEDIUM)
  isAnonymous Boolean           @default(false)

  // Optional: who / what the grievance is about
  againstUserId Int?
  againstUser   User? @relation("GrievanceAgainstUser", fields: [againstUserId], references: [id], onDelete: SetNull)

  // Assignment
  assignedToId Int?
  assignedTo   User? @relation("GrievanceAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Details
  title       String
  description String

  // Lifecycle
  status GrievanceStatus @default(OPEN)

  resolvedById   Int?
  resolvedBy     User?     @relation("GrievanceResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt     DateTime?
  resolutionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school       School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear          @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  attachments  GrievanceAttachment[]
  comments     GrievanceComment[]

  @@index([schoolId, academicYearId])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([raisedById])
}

model GrievanceComment {
  id          Int    @id @default(autoincrement())
  grievanceId Int
  userId      Int // The person commenting
  message     String

  createdAt DateTime @default(now())

  grievance Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GrievanceAttachment {
  id           Int    @id @default(autoincrement())
  grievanceId  Int
  fileUrl      String
  uploadedById Int?

  uploadedAt DateTime @default(now())

  grievance  Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
}

// ==========================
// CONFIGURATION
// ==========================

model GrievanceConfig {
  id       Int @id @default(autoincrement())
  schoolId Int
  roleId   Int

  isEnabled Boolean @default(true)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([schoolId, roleId])
  @@index([schoolId])
}
