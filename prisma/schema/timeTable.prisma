enum TimetableOverrideType {
  SUBSTITUTE
  CANCELLED
  ROOM_CHANGE
  TEACHER_SWAP
  EXTRA_CLASS
  HOLIDAY
}

enum PeriodType {
  TEACHING
  BREAK
  ASSEMBLY
}

enum TimetableStatus {
  DRAFT
  PUBLISHED
  LOCKED
}

model TimetableSettings {
  id Int @id @default(autoincrement())

  schoolId Int @unique

  allowSubstitution Boolean @default(true)
  allowCancellation Boolean @default(true)
  allowTeacherSwap  Boolean @default(false)

  requireTeacher Boolean @default(true)
  requireRoom    Boolean @default(false)

  allowFlexiblePeriods  Boolean @default(false)
  allowMultipleTeachers Boolean @default(false)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Schedule {
  id             Int @id @default(autoincrement())
  schoolId       Int
  academicYearId Int

  name        String // "Primary Schedule", "Senior Schedule", "Exam Schedule"
  description String?
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timePeriods    TimePeriod[]
  classes        Class[]
  academicGroups AcademicGroup[]
  timeSlots      TimeSlot[]

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, academicYearId])
  @@map("schedules")
}

model TimePeriod {
  id             Int  @id @default(autoincrement())
  schoolId       Int
  academicYearId Int
  scheduleId     Int?

  name      String // P1, P2, Assembly
  startTime String // "09:00"
  endTime   String // "09:45"

  type PeriodType  @default(TEACHING)
  days DayOfWeek[] // Applicable days for this period

  createdAt DateTime @default(now())

  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  schedule           Schedule?           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  timeSlots          TimeSlot[]
  attendanceSessions AttendanceSession[]

  @@unique([schoolId, academicYearId, scheduleId, name])
  @@unique([id, schoolId])
  @@index([schoolId])
}

model TimetableEntry {
  id Int @id @default(autoincrement())

  // Tenant & academic isolation
  schoolId       Int
  academicYearId Int

  // Academic mapping
  groupId   Int
  subjectId Int?
  teacherId Int?

  // Time & Block Handling
  day          DayOfWeek
  timeSlotId   Int
  durationSlots Int     @default(1) // Number of consecutive slots this entry occupies (e.g., 2 for a double lab)
  isBlockStart Boolean @default(true) // To identify the first entry in a sequence

  // Optional room (primary, legacy support)
  roomId Int?

  // Workflow & Locking
  isLocked    Boolean         @default(false)
  status      TimetableStatus @default(DRAFT)
  publishedAt DateTime?
  publishedBy Int?

  isFixed Boolean @default(false) // assembly, lunch

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  group              AcademicGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject            Subject?            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher            TeacherProfile?     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  room               Room?               @relation(fields: [roomId], references: [id], onDelete: SetNull)
  timeSlot           TimeSlot            @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
  publisher          User?               @relation("TimetablePublisher", fields: [publishedBy], references: [id], onDelete: SetNull)
  timetableOverrides TimetableOverride[]

  // Multi-Resource Relations
  teachers TimetableEntryTeacher[]
  rooms    TimetableEntryRoom[]

  // Prevent double booking (Standard single slot)
  @@unique([schoolId, academicYearId, groupId, day, timeSlotId]) 
  // Note: Complex conflict detection for blocks will be handled in service layer
  @@unique([id, schoolId])
  @@index([teacherId])
  @@index([roomId])
}

//-------------------------------------------------------------
// MULTI-RESOURCE JUNCTIONS
//-------------------------------------------------------------
model TimetableEntryTeacher {
  id      Int @id @default(autoincrement())
  entryId Int
  teacherId Int

  entry   TimetableEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([entryId, teacherId])
  @@index([teacherId])
}

model TimetableEntryRoom {
  id     Int @id @default(autoincrement())
  entryId Int
  roomId  Int

  entry TimetableEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  room  Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([entryId, roomId])
  @@index([roomId])
}

model TimetableOverride {
  id Int @id @default(autoincrement())

  schoolId       Int
  academicYearId Int
  entryId        Int
  date           DateTime

  type TimetableOverrideType

  substituteTeacherId Int?
  substituteRoomId    Int?
  note                String?

  createdById Int?
  createdAt   DateTime @default(now())

  entry             TimetableEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear      AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  substituteTeacher TeacherProfile? @relation(fields: [substituteTeacherId], references: [id])
  substituteRoom    Room?           @relation(fields: [substituteRoomId], references: [id])
  createdBy         User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([schoolId, entryId, date])
  @@index([schoolId, date])
}
